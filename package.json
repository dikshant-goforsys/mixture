{
  "name": "mixture",
  "version": "0.1.0",
  "private": true,
  "description": "A deliberately-small, layered skills + agents framework for Claude Code.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mixture": "bin/mixture.mjs"
  },
  "files": [
    "bin",
    "skills",
    "scripts",
    "hooks",
    "manifests",
    "references",
    "coordination",
    "how-to-use.md",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "validate": "node scripts/validate-frontmatter.mjs",
    "drift": "node scripts/check-drift.mjs --ci",
    "hooks:resolve": "node scripts/resolve-hooks.mjs",
    "hooks:check": "node scripts/resolve-hooks.mjs --check",
    "test:coord": "node coordination/tests.mjs",
    "ci": "npm run validate && npm run drift && npm run hooks:check && npm run test:coord"
  }
}
