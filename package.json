{
  "name": "mixture-skills",
  "version": "0.3.2",
  "description": "A deliberately-small, layered skills + agents framework for Claude Code. Install skills, session memory, and a multi-agent task runtime into any project.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "agent-skills",
    "ai-agents",
    "coding-agent",
    "mixture"
  ],
  "bin": {
    "mixture-skills": "bin/mixture.mjs",
    "mixture": "bin/mixture.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dikshant-goforsys/mixture.git"
  },
  "homepage": "https://github.com/dikshant-goforsys/mixture#readme",
  "bugs": {
    "url": "https://github.com/dikshant-goforsys/mixture/issues"
  },
  "files": [
    "bin",
    "skills",
    ".claude/agents",
    "scripts",
    "hooks",
    "manifests",
    "references",
    "coordination",
    "how-to-use.md",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "validate": "node scripts/validate-frontmatter.mjs",
    "drift": "node scripts/check-drift.mjs --ci",
    "hooks:resolve": "node scripts/resolve-hooks.mjs",
    "hooks:check": "node scripts/resolve-hooks.mjs --check",
    "test:coord": "node coordination/tests.mjs",
    "ci": "npm run validate && npm run drift && npm run hooks:check && npm run test:coord",
    "prepublishOnly": "npm run ci"
  }
}
